    %% Initial UML — data classes (Owner, Pet, Task, Plan) + logic class (Scheduler).

    class Owner {
        +str name
        +str preferences
    }

    class Pet {
        +str name
        +str species
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
    }

    class Scheduler {
        +generate_plan(tasks, available_minutes) Plan
    }

    class Plan {
        +list~Task~ tasks
        +str reasoning
    }

    Owner --> Pet : has
    Pet --> Task : has
    Scheduler --> Task : takes
    Scheduler --> Plan : produces
    Plan --> Task : orders
